              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "Redireciona para Azure AD para autenticação. Após login bem-sucedido, retorna com JWT em cookie."
          },
          "response": []
