    {
      "name": "Chat",
      "description": "Endpoints para chat com LLM",
      "item": [
        {
          "name": "Ask Question",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chat_id\": \"session_abc123\",\n  \"user_id\": \"alice\",\n  \"name\": \"Alice Silva\",\n  \"email\": \"alice@company.com\",\n  \"country\": \"Brazil\",\n  \"city\": \"São Paulo\",\n  \"roles\": [\"Employee\"],\n  \"department\": \"TI\",\n  \"job_title\": \"Analista\",\n  \"collar\": \"white\",\n  \"unit\": \"Engineering\",\n  \"question\": \"Quais são os benefícios de saúde disponíveis?\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat/question",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "question"]
            },
            "description": "Fazer pergunta e obter resposta do LLM\n\nO backend:\n1. Busca documentos relevantes\n2. Filtra por role/país/cidade do usuário\n3. Envia para LLM Server com contexto\n4. Retorna resposta + fontes\n5. Salva conversa no banco"
          },
          "response": []
