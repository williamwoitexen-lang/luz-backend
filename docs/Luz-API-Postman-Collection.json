    {
      "name": "Documents - Ingestion",
      "description": "Endpoints para ingestão de documentos (upload, preview, confirm)",
      "item": [
        {
          "name": "1. Preview - Extract Metadata",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/documents/ingest-preview",
              "host": ["{{baseUrl}}"],
              "path": ["documents", "ingest-preview"]
            },
            "description": "Etapa 1: Upload arquivo para preview\n\nO backend:\n1. Salva arquivo em storage/temp/{temp_id}/\n2. Extrai texto\n3. Chama LLM para sugerir metadados\n4. Retorna temp_id + sugestões\n\nArquivo expira em 10 minutos se não confirmar."
          },
          "response": []
        },
        {
          "name": "2. Confirm - Finalize Ingestion",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "user_id",
                  "value": "alice",
                  "type": "text"
                },
                {
                  "key": "allowed_countries",
                  "value": "[\"BR\", \"US\"]",
                  "type": "text",
                  "description": "JSON array ou comma-separated"
                },
                {
                  "key": "allowed_cities",
                  "value": "[\"SP\", \"RJ\"]",
                  "type": "text"
                },
                {
                  "key": "category_id",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "title",
                  "value": "Policy Document",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/documents/ingest-confirm/:temp_id",
              "host": ["{{baseUrl}}"],
              "path": ["documents", "ingest-confirm", ":temp_id"],
              "variable": [
                {
                  "key": "temp_id",
                  "value": "550e8400-e29b-41d4"
                }
              ]
            },
            "description": "Etapa 2: Confirmar ingestão\n\nSubstituir :temp_id com valor do preview\n\nO backend:\n1. Recupera arquivo do temp\n2. Valida metadados\n3. Chama LLM para indexar\n4. Salva em SQL Server\n5. Move arquivo para permanente\n6. Deleta temp\n\nResultado: Documento pronto para busca"
          },
          "response": []
        },
        {
          "name": "Direct Ingest (em 1 etapa)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "user_id",
                  "value": "alice",
                  "type": "text"
                },
                {
                  "key": "allowed_countries",
                  "value": "BR,US",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/documents/ingest",
              "host": ["{{baseUrl}}"],
              "path": ["documents", "ingest"]
            },
            "description": "Ingerir documento em uma única etapa (sem preview)\n\nAlternativa rápida ao fluxo 2-step"
          },
          "response": []
        }
      ]
    },
