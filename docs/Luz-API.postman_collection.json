{
  "info": {
    "_postman_id": "luz-backend-api-collection-2026",
    "name": "Luz Backend API",
    "description": "API Collection para Plataforma Luz - Backend FastAPI\n\nContém todos os endpoints disponíveis:\n- Autenticação (MSAL + Entra ID)\n- Documentos (Ingestão, CRUD, Busca)\n- Chat com IA (LLM Integration)\n- Dados Mestres (Locais, Cargos, Categorias)\n- Dashboard (Análise de conversas)\n- Admin Management (Auditoria)\n\nVariáveis de environment configuradas:\n- {{baseUrl}}: http://localhost:8000/api/v1\n- {{token}}: JWT token (preenchido após login)\n- {{temp_id}}: ID temporário (da etapa de preview)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "temp_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "1. Login - Redirecionar para Azure AD",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "Redireciona para Azure AD para autenticação. Frontend deve seguir o redirect."
          },
          "response": []
        },
        {
          "name": "2. Get Token - Callback após Azure Login",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/getatoken?code=YOUR_AUTH_CODE",
              "host": ["{{baseUrl}}"],
              "path": ["getatoken"],
              "query": [
                {
                  "key": "code",
                  "value": "YOUR_AUTH_CODE"
                }
              ]
            },
            "description": "Chamado automaticamente pelo Azure. Troca código por JWT."
          },
          "response": []
        },
        {
          "name": "3. Check Auth Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/status",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "status"]
            },
            "description": "Verifica se usuário está autenticado (valida JWT do cookie)"
          },
          "response": []
        },
        {
          "name": "4. Get User Role",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/me/role",
              "host": ["{{baseUrl}}"],
              "path": ["me", "role"]
            },
            "description": "Retorna role do usuário autenticado"
          },
          "response": []
        },
        {
          "name": "5. Logout",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/logout",
              "host": ["{{baseUrl}}"],
              "path": ["logout"]
            },
            "description": "Faz logout (remove JWT cookie)"
          },
          "response": []
        }
      ]
    },
