    {
      "name": "📄 Documents - Ingest",
      "item": [
        {
          "name": "1. Ingest Preview (Extract Metadata)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/documents/ingest-preview",
              "host": ["{{baseUrl}}"],
              "path": ["documents", "ingest-preview"]
            },
            "description": "Etapa 1: Upload arquivo temporário + LLM extrai metadados sugeridos\n\nRetorna: temp_id, extracted_fields, expires_in_seconds"
          },
          "response": []
        },
        {
          "name": "2. Ingest Confirm (with extracted metadata)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "user_id",
                  "value": "alice@company.com",
                  "type": "text"
                },
                {
                  "key": "allowed_countries",
                  "value": "[\"BR\", \"US\"]",
                  "type": "text"
                },
                {
                  "key": "allowed_cities",
                  "value": "[\"São Paulo\", \"New York\"]",
                  "type": "text"
                },
                {
                  "key": "category_id",
                  "value": "5",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/documents/ingest-confirm/{{temp_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["documents", "ingest-confirm", "{{temp_id}}"]
            },
            "description": "Etapa 2: Confirmar ingestão com metadados finais\n\nUsa temp_id do preview anterior\nRetorna: document_id, status, version"
          },
          "response": []
        },
        {
          "name": "3. Direct Ingest (Upload + Index)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "user_id",
                  "value": "alice@company.com",
                  "type": "text"
                },
                {
                  "key": "allowed_countries",
                  "value": "Brazil,USA",
                  "type": "text"
                },
                {
                  "key": "allowed_cities",
                  "value": "São Paulo,New York",
                  "type": "text"
                },
                {
                  "key": "category_id",
                  "value": "5",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/documents/ingest",
              "host": ["{{baseUrl}}"],
              "path": ["documents", "ingest"]
            },
            "description": "Ingestão direta: upload + processamento em uma única request\n\nNÃO usa preview/confirm, mais rápido"
          },
          "response": []
        }
      ]
    },
