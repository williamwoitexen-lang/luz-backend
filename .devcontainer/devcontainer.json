{
    "name": "Vector Store FastAPI DevContainer",
    "dockerFile": "Dockerfile",
    "context": "..",

    "remoteUser": "root",

    "runArgs": [
        "--memory=8g",
        "--memory-swap=8g"
    ],

    "remoteEnv": {
        "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}"
    },

    "mounts": [
        "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
        "source=${localWorkspaceFolder}/.env,target=/workspaces/Embeddings/.env,type=bind"
    ],
    
    "postCreateCommand": "bash .devcontainer/post_create.sh",

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-azuretools.vscode-docker"
            ]
        }
    }
}
